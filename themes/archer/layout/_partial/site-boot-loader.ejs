<% if (!theme.boot_shader || theme.boot_shader.enable !== false) { %>
    <div id="site-boot-loader" class="site-boot-loader" data-session-once="<%- theme.boot_shader && theme.boot_shader.session_once === false ? 'false' : 'true' %>" data-min-duration="<%- theme.boot_shader && theme.boot_shader.min_duration ? theme.boot_shader.min_duration : 1800 %>" data-max-duration="<%- theme.boot_shader && theme.boot_shader.max_duration ? theme.boot_shader.max_duration : 5200 %>" role="status" aria-live="polite" aria-label="网站加载中">
        <canvas class="site-boot-canvas" aria-hidden="true"></canvas>
        <div class="site-boot-vignette" aria-hidden="true"></div>
        <div class="site-boot-content">
            <div class="site-boot-kicker">GGXD SYSTEM</div>
            <div class="site-boot-title">鸽鸽XD的小站</div>
            <div class="site-boot-status">正在载入飞行画面</div>
            <div class="site-boot-progress" aria-hidden="true"><span></span></div>
        </div>
    </div>
    <script>
        (function () {
            try {
                var shouldSkip = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
                if (!shouldSkip && sessionStorage.getItem('ggxd.siteBootLoader.seen') === '1') {
                    shouldSkip = true;
                }
                if (shouldSkip) {
                    document.documentElement.classList.add('site-boot-skip');
                }
            } catch (err) {}
        })();
    </script>
<% } %>
