<div class="site-intro" style="<%- partial('intro-height', {attr: 'height'}) %>">
    <%
        const introTags = []
        const collectTag = function (tag) {
            if (tag && tag.name && introTags.indexOf(tag.name) === -1) introTags.push(tag.name)
        }

        if (is_post() && page.tags && page.tags.length) {
            page.tags.forEach(collectTag)
        } else if (site.tags && site.tags.length) {
            site.tags.sort('name').each(collectTag)
        }

        if (is_post() && !introTags.length && page.categories && page.categories.length) {
            page.categories.forEach(collectTag)
        }

        if (!introTags.length) introTags.push(theme.main_title || config.title)
        const floatingTags = introTags.slice(0, 30)
    %>
    <div class="site-intro-placeholder"></div>
    <div class="site-intro-img site-intro-img-sentinel" style="background-image: url(data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///ywAAAAAAQABAAACAUwAOw==)"></div>
    <div class="site-intro-tags" aria-hidden="true">
        <% floatingTags.forEach(function (tagName, i) { %>
            <%
                const tagX = 8 + ((i * 37 + 11) % 84)
                const tagY = 12 + ((i * 29 + 7) % 70)
                const tagScale = (82 + ((i * 13) % 42)) / 100
                const tagDelay = -1 * ((i * 17) % 26)
                const tagDuration = 16 + ((i * 5) % 12)
                const tagRotate = ((i * 23) % 28) - 14
            %>
            <span class="site-intro-floating-tag tag-float-<%= i % 8 %>" style="--tag-x:<%= tagX %>%;--tag-y:<%= tagY %>%;--tag-scale:<%= tagScale %>;--tag-delay:<%= tagDelay %>s;--tag-duration:<%= tagDuration %>s;--tag-rotate:<%= tagRotate %>deg;"><%- tagName %></span>
        <% }) %>
    </div>
    <div class="site-intro-meta">
        <!-- 标题  -->
        <h1 class="intro-title">
            <!-- 主页  -->
            <% if (is_home()) { %>
                <%- theme.main_title || config.title %>
            <!-- 文章页  -->
            <% } else if(is_post()) { %>
                <%- truncate(strip_html(page.title), {length: 80, omission: '...'}) || '[Untitled Post]' %>
            <!-- 404 -->
            <% } else if(page.layout === "404") { %>
                <%- page.title || '[404]'%>
            <!-- about -->
            <% } else if(page.layout === "about" ) { %>
                <%- page.title || 'About' %>
            <% } else { %>
                <%- page.title || config.title %>
            <% } %>
        </h1>
        <!-- 副标题 -->
        <p class="intro-subtitle">
            <!-- 主页副标题  -->
            <% if (is_home()) { %>
                <% if(typeof theme.subtitle === 'string') { %>
                    <%- theme.subtitle %>
                <% } %>
            <!-- 文章页  -->
            <% } else if (is_post()) { %>
                <% if(typeof page.subtitle === 'string') { %>
                    <%- page.subtitle %>
                <% } %>
            <!-- 404 -->
            <% } else if (page.layout === "404") { %>
                <%- page.description %>
            <% } %>
        </p>
        <!-- 文章页 meta -->
        <% if(is_post()) { %>
            <div class="post-intros">
                <!-- 文章页标签  -->
                <% if(page.tags.length || page.categories) { %>
                    <%- partial('base-title-tags', {
                        currPost: page,
                        className: 'post-intro-tags'}) %>
                <% } %>
                <!-- 文章字数统计 -->
                <% if(theme.reading_info) { %>
                    <div class="post-intro-read">
                        <span><%- __('word_count') %>: <span class="post-count word-count"><%= wordcount(page.content) %></span><%= __('reading_time') %>: <span class="post-count reading-time"><%= min2read(page.content) %> min</span></span>
                    </div>
                <% } %>
                <div class="post-intro-meta">
                    <!-- 撰写日期 -->
                    <span class="iconfont-archer post-intro-calander">&#xe676;</span>
                    <span class="post-intro-time"><%- date(page.date, "YYYY/MM/DD") %></span>
                    <!-- busuanzi -->
                    <% if (theme.busuanzi) { %>
                        <span id="busuanzi_container_page_pv" class="busuanzi-pv">
                            <span class="iconfont-archer post-intro-busuanzi">&#xe602;</span>
                            <span id="busuanzi_value_page_pv"></span>
                        </span>
                    <% } %>
                </div>
            </div>
        <% } %>
    </div>
</div>
